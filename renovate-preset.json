{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": ["Default Renovate preset for batinicaz GitHub repos"],
  "pre-commit": { "enabled": true },
  "packageRules": [
    {
      "description": "Skip Renovate for internal GHA workflows (float on @v1)",
      "matchDatasources": ["github-actions"],
      "matchPackageNames": ["/^batinicaz\\/gha/"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "matchCurrentVersion": "<1.0.0",
      "automerge": false
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchManagers": ["pre-commit"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": ">=1.0.0",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "minimumReleaseAge": "3 days",
      "internalChecksFilter": "strict"
    },
    {
      "description": "Skip release age check for our own images",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/^ghcr\\.io\\/batinicaz\\//"],
      "minimumReleaseAge": "0 days"
    }
  ]
}

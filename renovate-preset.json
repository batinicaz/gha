{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": ["Default Renovate preset for batinicaz GitHub repos"],
  "osvVulnerabilityAlerts": true,
  "dependencyDashboardOsvVulnerabilitySummary": "all",
  "pre-commit": { "enabled": true },
  "packageRules": [
    {
      "description": "Skip Renovate for internal GHA workflows (float on @v1)",
      "matchDatasources": ["github-actions"],
      "matchPackageNames": ["/^batinicaz\\/gha/"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "matchCurrentVersion": "<1.0.0",
      "automerge": false
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchManagers": ["pre-commit"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Stabilisation window for external dependencies",
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": ["!/^ghcr\\.io\\/batinicaz\\//"],
      "minimumReleaseAge": "14 days",
      "internalChecksFilter": "strict"
    },
    {
      "description": "Disable automerge for pre-1.0 (docker versioning lacks range support, so regex supplements the <1.0.0 rule above)",
      "matchDatasources": ["docker"],
      "matchCurrentVersion": "/^0\\./",
      "automerge": false
    }
  ]
}

{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>batinicaz/gha:renovate-preset"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update terraform-docs version in shared actions and workflows",
      "fileMatch": [
        "^\\.github/actions/.*action\\.yml$",
        "^\\.github/workflows/terraform-docs\\.yml$"
      ],
      "matchStrings": ["terraform.docs.version[\\s\\S]*?default:\\s*\"(?<currentValue>v[\\d.]+)\""],
      "depNameTemplate": "terraform-docs/terraform-docs",
      "datasourceTemplate": "github-releases"
    }
  ]
}
